{
  "name": "@soshilabs/dev",
  "version": "1.0.0",
  "description": "AI-powered web development and SEO audit client — Soshi connector",
  "type": "module",
  "main": "./dist/tools.mjs",
  "bin": {
    "dev": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:tools",
    "build:tools": "node esbuild.config.mjs",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "soshi.manifest.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "inquirer": "^13.3.0",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
